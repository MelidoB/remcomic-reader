# ########################
# General Exclusions
# ########################
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db

# ########################
# IDE and Editor Configs
# ########################
.vscode/
.idea/
*.swp
*~
.Rhistory
.groupedtimelineinclude

# ########################
# Python / Backend
# ########################
/backend/venv/
/backend/**/__pycache__/
*.pyc

# User-specific local content (add .gitkeep to track empty folders)
/backend/chapters/*
!/backend/chapters/.gitkeep
/backend/cache/*
!/backend/cache/.gitkeep
/backend/src/web/static/results/*
!/backend/src/web/static/results/.gitkeep

# ########################
# AI Models & Voices
# ########################
/backend/src/models/**/*.pt
/backend/src/models/**/*.onnx
/backend/src/models/**/*.json

# ########################
# Frontend (Vue / Vite)
# ########################
/frontend/node_modules/
/frontend/dist/
/frontend/dist-ssr/
/frontend/.next/
/frontend/.cache/
/frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (NEVER commit these)
.env
.env.*
!.env.example

# ########################
# Tunnelling Tool
# ########################
ngrok
ngrok.exe
ngrok.yml